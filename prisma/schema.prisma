// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  Admin
  Vendor
  Customer
}

enum UserStatus {
  Active
  Pending
  Suspended
}

enum CertificationStatus {
  Pending
  Approved
  Rejected
}

enum ProduceCategory {
  Vegetables
  Fruits
  Grains
  Dairy
}

enum OrderStatus {
  Pending
  Confirmed
  Shipped
  Delivered
  Cancelled
}

enum PlantHealth {
  Seeding
  Sprouting
  Growing
  Flowering
  ReadyToHarvest
  Harvested
  Healthy
  Sick
  Dead
}

enum PaymentStatus {
  Pending
  Completed
  Failed
  Refunded
}

model User {
  id        Int         @id @default(autoincrement())
  name      String
  email     String      @unique
  password  String
  role      UserRole
  status    UserStatus
  profileImage String?
  createdAt DateTime    @default(now())

  vendorProfile         VendorProfile?
  orders                Order[]
  payments              Payment[]
  communityPosts        CommunityPost[]
  customerPosts         CustomerPost[]
  postLikes             PostLike[]
  postComments          PostComment[]
  customerPostLikes     CustomerPostLike[]
  customerPostComments  CustomerPostComment[]
  vendorPostLikes       VendorPostLike[]
  vendorPostComments    VendorPostComment[]
  userCommands          UserCommand[]
  notifications         Notification[]

  @@map("users")
}

model VendorProfile {
  id                 Int                @id @default(autoincrement())
  userId             Int                @unique
  farmName           String
  certificationStatus CertificationStatus @default(Pending)
  farmLocation       String
  profilePhoto       String?
  certifications     String[]
  createdAt          DateTime           @default(now())

  user               User               @relation(fields: [userId], references: [id])
  produces           Produce[]
  rentalSpaces       RentalSpace[]
  orders             Order[]
  sustainabilityCerts SustainabilityCert[]
  vendorPosts        VendorPost[]

  @@map("vendor_profiles")
}

model Produce {
  id                 Int                @id @default(autoincrement())
  vendorId           Int
  name               String
  description        String
  price              Float
  category           ProduceCategory
  certificationStatus CertificationStatus @default(Pending)
  availableQuantity  Int
  unit               String?
  isOrganic          Boolean?           @default(false)
  image              String?
  createdAt          DateTime           @default(now())

  vendor             VendorProfile @relation(fields: [vendorId], references: [id])
  orders             Order[]

  @@map("produces")
}

model RentalSpace {
  id           Int     @id @default(autoincrement())
  vendorId     Int
  location     String
  size         String
  price        Float
  availability Boolean @default(true)
  image        String?
  plantStatus  PlantHealth?
  lastWatered  DateTime?
  createdAt    DateTime @default(now())

  vendor       VendorProfile @relation(fields: [vendorId], references: [id])
  orders       Order[]

  @@map("rental_spaces")
}

model Order {
   id        Int        @id @default(autoincrement())
   userId    Int
   produceId Int?
   vendorId  Int
   rentalSpaceId Int?
   quantity  Int
   totalPrice Float
   status    OrderStatus @default(Pending)
   orderDate DateTime   @default(now())

   user    User           @relation(fields: [userId], references: [id])
   produce Produce?       @relation(fields: [produceId], references: [id])
   vendor  VendorProfile  @relation(fields: [vendorId], references: [id])
   rentalSpace RentalSpace? @relation(fields: [rentalSpaceId], references: [id])
   payments Payment[]

   @@map("orders")
 }

model Payment {
  id                Int           @id @default(autoincrement())
  orderId           Int
  userId            Int
  paymentIntentId   String        @unique
  amount            Float         // Amount in USD cents
  originalAmount    Float         // Original amount in BDT
  currency          String        @default("usd")
  status            PaymentStatus @default(Pending)
  paymentDate       DateTime      @default(now())

  order             Order         @relation(fields: [orderId], references: [id])
  user              User          @relation(fields: [userId], references: [id])

  @@map("payments")
}

model CommunityPost {
  id          Int      @id @default(autoincrement())
  userId      Int
  postContent String
  postDate    DateTime @default(now())
  isApproved  Boolean  @default(true)

  user        User @relation(fields: [userId], references: [id])
  likes       PostLike[]
  comments    PostComment[]

  @@map("community_posts")
}

model PostLike {
  id        Int    @id @default(autoincrement())
  userId    Int
  postId    Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  post CommunityPost @relation(fields: [postId], references: [id])

  @@unique([userId, postId])
  @@map("post_likes")
}

model PostComment {
  id        Int      @id @default(autoincrement())
  userId    Int
  postId    Int
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  post CommunityPost @relation(fields: [postId], references: [id])

  @@map("post_comments")
}

enum PostCategory {
  Question
  Discussion
  Review
  Suggestion
}

enum VendorPostCategory {
  FarmUpdate
  ProductShowcase
  Sustainability
  Community
}

model CustomerPost {
  id          Int          @id @default(autoincrement())
  userId      Int
  title       String
  content     String
  category    PostCategory
  isApproved  Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user        User @relation(fields: [userId], references: [id])
  likes       CustomerPostLike[]
  comments    CustomerPostComment[]

  @@map("customer_posts")
}

model CustomerPostLike {
  id        Int    @id @default(autoincrement())
  userId    Int
  postId    Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  post CustomerPost @relation(fields: [postId], references: [id])

  @@unique([userId, postId])
  @@map("customer_post_likes")
}

model CustomerPostComment {
  id        Int      @id @default(autoincrement())
  userId    Int
  postId    Int
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  post CustomerPost @relation(fields: [postId], references: [id])

  @@map("customer_post_comments")
}

model VendorPost {
  id          Int               @id @default(autoincrement())
  vendorId    Int
  title       String
  content     String
  category    VendorPostCategory
  image       String?
  isApproved  Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  vendor      VendorProfile @relation(fields: [vendorId], references: [id])
  likes       VendorPostLike[]
  comments    VendorPostComment[]

  @@map("vendor_posts")
}

model VendorPostLike {
  id        Int    @id @default(autoincrement())
  userId    Int
  postId    Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  post VendorPost @relation(fields: [postId], references: [id])

  @@unique([userId, postId])
  @@map("vendor_post_likes")
}

model VendorPostComment {
  id        Int      @id @default(autoincrement())
  userId    Int
  postId    Int
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  post VendorPost @relation(fields: [postId], references: [id])

  @@map("vendor_post_comments")
}

enum CommandType {
  SCRIPT
  QUERY
  ACTION
}

model UserCommand {
  id          Int         @id @default(autoincrement())
  userId      Int
  name        String
  description String?
  command     String
  type        CommandType @default(SCRIPT)
  isPublic    Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user        User @relation(fields: [userId], references: [id])

  @@map("user_commands")
}

enum NotificationType {
  ORDER_STATUS_UPDATE
  RENTAL_SPACE_BOOKED
  COMMUNITY_POST_LIKE
  COMMUNITY_POST_COMMENT
  PRODUCE_UPDATE
  SYSTEM
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  type      NotificationType
  title     String
  message   String
  data      Json?            // Additional data for the notification
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user      User @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model SustainabilityCert {
  id               Int      @id @default(autoincrement())
  vendorId         Int
  certifyingAgency String
  certificationDate DateTime

  vendor           VendorProfile @relation(fields: [vendorId], references: [id])

  @@map("sustainability_certs")
}