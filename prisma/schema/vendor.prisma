model VendorProfile {
  id                 String             @id @default(uuid())
  userId             String             @unique
  farmName           String
  certificationStatus CertificationStatus @default(Pending)
  farmLocation       String
  profilePhoto       String?
  user               User               @relation(fields: [userId], references: [id])
  produces           Produce[]
  rentalSpaces       RentalSpace[]
  sustainabilityCerts SustainabilityCert[]
  orders             Order[]
}

model Produce {
  id                   String             @id @default(uuid())
  vendorId             String
  name                 String
  description          String?
  price                Float
  category             String
  certificationStatus  CertificationStatus @default(Pending)
  availableQuantity    Int                @default(0)
  vendor               VendorProfile      @relation(fields: [vendorId], references: [id])
  orders               Order[]
}

model RentalSpace {
  id           String        @id @default(uuid())
  vendorId     String
  location     String
  size         String        // e.g., "10x10 sq ft"
  price        Float
  availability Boolean       @default(true)
  vendor       VendorProfile @relation(fields: [vendorId], references: [id])
}

model SustainabilityCert {
  id                String   @id @default(uuid())
  vendorId          String
  certifyingAgency  String
  certificationDate DateTime
  vendor            VendorProfile @relation(fields: [vendorId], references: [id])
}